  "keyFeatures": [
    "AI-powered repository analysis with comprehensive health scoring",
    "Interactive architecture and data flow diagram generation",
    "Multi-format export (PDF, Markdown, plain text, shareable images)",
    "Branch-level analysis with comparison capabilities",
    "User authentication with tiered pricing (Free & Pro plans)",
    "Real-time streaming analysis with progress updates",
    "Dependency analysis and security insights",
    "Smart caching for instant re-analysis",
    "Dark/Light mode with responsive design"
  ],
  "publicApiSurface": [
    "POST /api/analyze - Analyze a GitHub repository",
    "GET /api/branches - Fetch repository branches",
    "GET /api/github-info - Get GitHub repository information",
    "GET /api/github-stars - Get repository star count",
    "POST /api/auth/[...nextauth] - NextAuth authentication endpoints",
    "GET /api/auth/account - Get user account information",
    "GET /api/auth/usage - Get user usage statistics",
    "/share/[owner]/[repo] - Shareable analysis page"
  ]
